{
  "name": "spacechild-auth",
  "version": "1.0.0",
  "description": "Standalone SpaceChild authentication and authorization service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/schema.sql','dist/schema.sql')\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "auth",
    "authentication",
    "authorization",
    "jwt",
    "oauth2",
    "oidc",
    "zkp",
    "mfa",
    "webauthn",
    "totp"
  ],
  "author": "SpaceChild Team",
  "license": "MIT",
  "dependencies": {
    "@simplewebauthn/server": "^9.0.3",
    "@simplewebauthn/types": "^9.0.1",
    "@types/dotenv": "^6.1.1",
    "bcryptjs": "^2.4.3",
    "circomlibjs": "^0.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
