# ================================
# Core Configuration
# ================================

# Required: Session secret for JWT signing and encryption (min 32 chars)
SESSION_SECRET=your-super-secret-session-key-minimum-32-characters

# Server configuration
PORT=3100
NODE_ENV=development

# CORS configuration (comma-separated origins)
CORS_ORIGINS=https://spacechild.love,http://localhost:3000

# ================================
# Database Configuration (Dolt/MySQL)
# ================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=spacechild_auth

# ================================
# Email Configuration
# ================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@spacechild.love

# Application URL for email links
APP_URL=https://auth.spacechild.love

# ================================
# WebAuthn Configuration
# ================================

# Your domain for WebAuthn (no protocol)
WEBAUTHN_RP_ID=spacechild.love

# Full origin URL for WebAuthn
WEBAUTHN_ORIGIN=https://spacechild.love

# ================================
# Optional: OAuth2 Configuration
# ================================

# Default OAuth2 client (if needed for compatibility)
OAUTH2_DEFAULT_CLIENT_ID=spacechild-auth
OAUTH2_DEFAULT_CLIENT_SECRET=your-oauth2-client-secret

# ================================
# Development/Testing
# ================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable debug mode
DEBUG=false